---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description,
  ogImage = 'https://cineindustria.com/assets/site/og-card.jpg',
  ogType = 'website',
  canonical = Astro.url.href,
  structuredData,
} = Astro.props;

import '../styles/global.css';
import SearchOverlay from '../components/SearchOverlay.astro';

const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CineIndustria",
  "url": "https://cineindustria.com/",
  "description": description,
  "inLanguage": "es-CL",
  "publisher": {
    "@type": "Organization",
    "name": "CineIndustria",
    "url": "https://cineindustria.com/",
    "logo": "https://cineindustria.com/assets/icons/icon-512.png"
  }
};

const jsonLd = structuredData || defaultStructuredData;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="cine, imagen, archivo, ensayo visual, cultura visual, referencias visuales, diseño, software, inteligencia artificial, latinoamerica" />
    <meta name="author" content="CineIndustria" />
    <meta name="creator" content="CineIndustria" />
    <meta name="publisher" content="CineIndustria" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="googlebot" content="index,follow,max-image-preview:large" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no, address=no, email=no" />
    <meta name="application-name" content="CineIndustria" />
    <meta name="apple-mobile-web-app-title" content="CineIndustria" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#141517" />
    <meta name="msapplication-TileColor" content="#141517" />
    <meta name="color-scheme" content="light only" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="CineIndustria" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image:url" content={ogImage} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="CineIndustria, plataforma editorial sobre cine, imagen y archivo." />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="CineIndustria: plataforma editorial sobre cine, imagen y archivo desde Latinoamérica." />

    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="CineIndustria — Ensayos" href="/rss.xml" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" href="/assets/icons/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/icons/favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="icon" href="/assets/icons/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/assets/icons/favicon-64.png" sizes="64x64" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" sizes="180x180" />
    <link rel="mask-icon" href="/assets/icons/safari-pinned-tab.svg" color="#141517" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <link rel="preload" href="/assets/icons/logo-mark.png" as="image" fetchpriority="high" />
    <link rel="preload" href="/assets/fonts/archivo-subset.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/public-sans-subset.woff2" as="font" type="font/woff2" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body>
    <slot />
    <SearchOverlay />
  </body>
</html>
