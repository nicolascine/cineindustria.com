---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const peliculas = await getCollection('peliculas');
  return peliculas.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Movie",
  "name": entry.data.title,
  "description": entry.data.ogDescription || entry.data.description,
  "director": {
    "@type": "Person",
    "name": entry.data.director,
  },
  "dateCreated": entry.data.year,
  "image": `https://cineindustria.com${entry.data.image}`,
  "review": {
    "@type": "Review",
    "author": {
      "@type": "Organization",
      "name": "CineIndustria",
    },
    "reviewBody": entry.data.description,
  },
};
---

<Base
  title={`${entry.data.title} — CineIndustria`}
  description={entry.data.ogDescription || entry.data.description}
  ogType="article"
  structuredData={structuredData}
>
  <div class="relative z-0 w-[min(calc(100%-20px),1220px)] md:w-[min(calc(100%-32px),1220px)] mx-auto pt-3 md:pt-5 pb-10 overflow-hidden">
    <Header showBack />

    <main id="top" class="grid gap-7">
      <article class="border border-[var(--color-line)] rounded-3xl lg:rounded-[34px] bg-[var(--color-paper-panel)] shadow-[var(--shadow-sm)] p-[22px] lg:p-[clamp(28px,4vw,52px)]">
        <div class="grid gap-3.5 mb-9 pb-7 border-b border-[var(--color-line)]">
          <div class="rounded-[20px] lg:rounded-[var(--radius-lg)] overflow-hidden mb-2">
            <img
              src={entry.data.image}
              alt={entry.data.title}
              width="1400"
              height="700"
              loading="eager"
              decoding="async"
              class="w-full h-[clamp(300px,40vw,500px)] object-cover"
            />
          </div>
          <div>
            <p class="m-0 mb-3 text-[var(--color-ink-soft)] font-[family-name:var(--font-archivo)] text-[0.76rem] leading-none tracking-[0.16em] uppercase">{entry.data.label}</p>
            <h1 class="m-0 font-[family-name:var(--font-archivo)] font-semibold text-[clamp(2rem,10vw,3rem)] lg:text-[clamp(2.4rem,6vw,4.4rem)] leading-[0.94] tracking-[-0.06em]">{entry.data.title}</h1>
            <div class="flex flex-wrap gap-2.5 mt-1">
              <span class="py-2 px-3.5 rounded-full border border-[var(--color-line)] font-[family-name:var(--font-archivo)] text-[0.74rem] tracking-[0.12em] uppercase">{entry.data.director}</span>
              <span class="py-2 px-3.5 rounded-full border border-[var(--color-line)] font-[family-name:var(--font-archivo)] text-[0.74rem] tracking-[0.12em] uppercase">{entry.data.year}</span>
            </div>
            <p class="m-0 mt-3.5 text-[var(--color-ink-soft)] text-[1.1rem] leading-[1.7] max-w-[56ch]">{entry.data.description}</p>
          </div>
        </div>

        <div class="max-w-[720px] prose">
          <Content />
        </div>

        <div class="mt-9 pt-7 border-t border-[var(--color-line)]">
          <a href="/#peliculas" class="button min-h-[48px] w-full md:w-auto inline-flex items-center justify-center px-[18px] rounded-full border border-[var(--color-line-strong)] no-underline uppercase tracking-[0.08em] font-[family-name:var(--font-archivo)] text-[0.76rem] bg-[rgba(255,255,255,0.44)]">&larr; Volver a películas</a>
        </div>
      </article>
    </main>

    <Footer />
  </div>
</Base>
