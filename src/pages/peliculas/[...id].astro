---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const peliculas = await getCollection('peliculas');
  return peliculas.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Movie",
  "name": entry.data.title,
  "description": entry.data.ogDescription || entry.data.description,
  "director": {
    "@type": "Person",
    "name": entry.data.director,
  },
  "dateCreated": entry.data.year,
  "image": `https://cineindustria.com${entry.data.image}`,
  "review": {
    "@type": "Review",
    "author": {
      "@type": "Organization",
      "name": "CineIndustria",
    },
    "reviewBody": entry.data.description,
  },
};
---

<Base
  title={`${entry.data.title} — CineIndustria`}
  description={entry.data.ogDescription || entry.data.description}
  ogType="article"
  structuredData={structuredData}
>
  <div class="site-shell">
    <Header showBack />

    <main id="top">
      <article class="detail-page">
        <div class="detail-header detail-header-film">
          <div class="detail-film-image">
            <img
              src={entry.data.image}
              alt={entry.data.title}
              width="1400"
              height="700"
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="detail-film-info">
            <p class="section-kicker">{entry.data.label}</p>
            <h1>{entry.data.title}</h1>
            <div class="detail-film-meta">
              <span>{entry.data.director}</span>
              <span>{entry.data.year}</span>
            </div>
            <p class="detail-lead">{entry.data.description}</p>
          </div>
        </div>

        <div class="detail-content prose">
          <Content />
        </div>

        <div class="detail-back">
          <a href="/#peliculas" class="button button-ghost">&larr; Volver a películas</a>
        </div>
      </article>
    </main>

    <Footer />
  </div>
</Base>
