---
interface Props {
  showBack?: boolean;
}
const { showBack = false } = Astro.props;
---

<header class="sticky top-3 md:top-[18px] z-20 flex flex-col md:flex-row items-stretch md:items-center justify-between gap-[18px] mb-7 p-3.5 px-4 border border-[var(--color-line)] rounded-3xl md:rounded-full bg-[rgba(248,242,235,0.76)] backdrop-blur-[18px] backdrop-saturate-[140%] shadow-[var(--shadow-sm)]">
  {showBack ? (
    <a class="brandmark inline-flex items-center justify-between md:justify-start gap-3.5 no-underline" href="/" aria-label="Volver a CineIndustria">
      <span class="brandmark-mark relative w-[78px] h-[60px] grid place-items-center flex-none">
        <img
          src="/assets/icons/logo-mark.png"
          alt="Logo CineIndustria"
          width="120"
          height="90"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="relative z-[1] w-[78px] drop-shadow-[0_12px_18px_rgba(21,21,23,0.12)]"
        />
      </span>
      <span class="grid gap-[3px]">
        <strong class="inline-flex items-center gap-2.5 font-[family-name:var(--font-archivo)] text-[1.14rem] leading-[0.94] tracking-[-0.04em]">CineIndustria</strong>
        <small class="text-[var(--color-ink-soft)] text-[0.7rem] uppercase tracking-[0.16em]">cine / imagen / archivo</small>
      </span>
    </a>
  ) : (
    <a class="brandmark inline-flex items-center justify-between md:justify-start gap-3.5 no-underline" href="#top" aria-label="CineIndustria">
      <span class="brandmark-mark relative w-[78px] h-[60px] grid place-items-center flex-none">
        <img
          src="/assets/icons/logo-mark.png"
          alt="Logo CineIndustria"
          width="120"
          height="90"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="relative z-[1] w-[78px] drop-shadow-[0_12px_18px_rgba(21,21,23,0.12)]"
        />
      </span>
      <span class="grid gap-[3px]">
        <strong class="inline-flex items-center gap-2.5 font-[family-name:var(--font-archivo)] text-[1.14rem] leading-[0.94] tracking-[-0.04em]">CineIndustria</strong>
        <small class="text-[var(--color-ink-soft)] text-[0.7rem] uppercase tracking-[0.16em]">cine / imagen / archivo</small>
      </span>
    </a>
  )}

  <nav class="site-nav flex items-center gap-2.5 overflow-x-auto whitespace-nowrap scrollbar-hide w-full md:w-auto pb-0.5 md:pb-0" aria-label="Secciones">
    {showBack ? (
      <>
        <a href="/#preguntas" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Preguntas</a>
        <a href="/#ensayos" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Ensayos</a>
        <a href="/#peliculas" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Películas</a>
        <a href="/#laboratorio" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Laboratorio</a>
      </>
    ) : (
      <>
        <a href="#preguntas" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Preguntas</a>
        <a href="#ensayos" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Ensayos</a>
        <a href="#peliculas" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Películas</a>
        <a href="#laboratorio" class="min-h-[38px] md:min-h-[40px] inline-flex items-center justify-center px-3 md:px-3.5 rounded-full border border-transparent no-underline uppercase tracking-[0.1em] font-[family-name:var(--font-archivo)] text-[0.74rem]">Laboratorio</a>
      </>
    )}
  </nav>
</header>
