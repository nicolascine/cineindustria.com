---
interface Props {
  showBack?: boolean;
}
const { showBack = false } = Astro.props;
---

<header class="site-header">
  {showBack ? (
    <a class="brandmark" href="/" aria-label="Volver a CineIndustria">
      <span class="brandmark-mark">
        <img
          src="/assets/icons/logo-mark.png"
          alt="Logo CineIndustria"
          width="120"
          height="90"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </span>
      <span class="brandmark-copy">
        <strong>CineIndustria</strong>
        <small>cine / imagen / archivo</small>
      </span>
    </a>
  ) : (
    <a class="brandmark" href="#top" aria-label="CineIndustria">
      <span class="brandmark-mark">
        <img
          src="/assets/icons/logo-mark.png"
          alt="Logo CineIndustria"
          width="120"
          height="90"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </span>
      <span class="brandmark-copy">
        <strong>CineIndustria</strong>
        <small>cine / imagen / archivo</small>
      </span>
    </a>
  )}

  <nav class="site-nav" aria-label="Secciones">
    {showBack ? (
      <>
        <a href="/#preguntas">Preguntas</a>
        <a href="/#ensayos">Ensayos</a>
        <a href="/#peliculas">Películas</a>
        <a href="/#laboratorio">Laboratorio</a>
      </>
    ) : (
      <>
        <a href="#preguntas">Preguntas</a>
        <a href="#ensayos">Ensayos</a>
        <a href="#peliculas">Películas</a>
        <a href="#laboratorio">Laboratorio</a>
      </>
    )}
    <button
      class="theme-toggle"
      id="theme-toggle"
      type="button"
      aria-label="Cambiar tema"
      title="Cambiar tema"
    >
      <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>
</header>
