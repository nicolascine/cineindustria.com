---
---

<footer class="site-footer" id="laboratorio">
  <div class="footer-top">
    <div class="footer-mark">
      <p class="section-kicker">Laboratorio</p>
      <h2>Hackear la imagen. Defender el montaje.</h2>
    </div>
    <div class="footer-panel">
      <p>
        Cineastas, artistas, técnicos y libre pensadores leyendo la imagen desde Latinoamérica.
      </p>
      <p>
        Cine, teoría crítica, archivo, software e IA sin obediencia al sistema cultural dominante.
      </p>
    </div>
  </div>

  <!-- Newsletter -->
  <div class="newsletter-band" id="newsletter">
    <div class="newsletter-copy">
      <p class="section-kicker">Señal</p>
      <h3>Recibir la señal.</h3>
      <p>Ensayos, referencias y notas de laboratorio. Sin spam, sin algoritmo.</p>
    </div>
    <form class="newsletter-form" id="newsletter-form" action="#" method="POST">
      <input
        type="email"
        name="email"
        placeholder="tu@email.com"
        required
        autocomplete="email"
        aria-label="Correo electrónico"
        class="newsletter-input"
      />
      <button type="submit" class="button button-ink newsletter-submit">Suscribirse</button>
    </form>
  </div>

  <div class="footer-rows">
    <article class="footer-column">
      <span>Base</span>
      <p>cine / teoría de la imagen / archivo / montaje</p>
    </article>
    <article class="footer-column">
      <span>Práctica</span>
      <p>piezas / ensayos / cuadernos / sistemas editoriales</p>
    </article>
  </div>

  <div class="footer-bottom">
    <strong>CineIndustria</strong>
    <span>señal en desarrollo &bull; online</span>
  </div>
</footer>
