---
import { getCollection } from 'astro:content';

const ensayos = await getCollection('ensayos');
const peliculas = await getCollection('peliculas');

const searchIndex = [
  ...ensayos.map((e) => ({
    type: 'ensayo' as const,
    title: e.data.title,
    description: e.data.description,
    author: e.data.author,
    year: e.data.year,
    url: `/ensayos/${e.id}/`,
  })),
  ...peliculas.map((p) => ({
    type: 'película' as const,
    title: p.data.title,
    description: p.data.description,
    director: 'director' in p.data ? (p.data as any).director : '',
    year: p.data.year,
    url: `/peliculas/${p.id}/`,
  })),
];
---

<div class="search-overlay" id="search-overlay" role="dialog" aria-modal="true" aria-label="Buscar" hidden>
  <div class="search-panel">
    <div class="search-header">
      <input
        type="search"
        id="search-input"
        class="search-input"
        placeholder="Buscar ensayos, películas..."
        autocomplete="off"
        aria-label="Buscar contenido"
      />
      <button type="button" class="search-close" id="search-close" aria-label="Cerrar búsqueda">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
    <div class="search-results" id="search-results"></div>
    <div class="search-hint">
      <kbd>/</kbd> para buscar &middot; <kbd>Esc</kbd> para cerrar
    </div>
  </div>
</div>

<script define:vars={{ searchIndex }}>
  window.__searchIndex = searchIndex;
</script>

<script>
  const overlay = document.getElementById('search-overlay')!;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results')!;
  const closeBtn = document.getElementById('search-close')!;
  const index = (window as any).__searchIndex as Array<{
    type: string; title: string; description: string; url: string;
    author?: string; director?: string; year: string;
  }>;

  function openSearch() {
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => input.focus());
  }

  function closeSearch() {
    overlay.hidden = true;
    document.body.style.overflow = '';
    input.value = '';
    results.innerHTML = '';
  }

  function search(query: string) {
    if (!query.trim()) {
      results.innerHTML = '';
      return;
    }
    const q = query.toLowerCase();
    const matches = index.filter((item) => {
      const text = `${item.title} ${item.description} ${item.author || ''} ${item.director || ''} ${item.year}`.toLowerCase();
      return text.includes(q);
    });

    if (matches.length === 0) {
      results.innerHTML = '<div class="search-empty">Sin resultados</div>';
      return;
    }

    results.innerHTML = matches.map((item) => `
      <a href="${item.url}" class="search-result">
        <span class="search-result-type">${item.type}</span>
        <strong>${item.title}</strong>
        <span class="search-result-meta">${item.author || item.director || ''} / ${item.year}</span>
      </a>
    `).join('');
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !overlay.hidden === false && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape' && !overlay.hidden) {
      closeSearch();
    }
  });

  closeBtn.addEventListener('click', closeSearch);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeSearch();
  });
  input.addEventListener('input', () => search(input.value));

  // Expose for header search button
  (window as any).__openSearch = openSearch;
</script>
